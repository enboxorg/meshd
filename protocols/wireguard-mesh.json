{
  "protocol": "https://enbox.id/protocols/wireguard-mesh",
  "published": true,
  "types": {
    "network": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/network",
      "dataFormats": ["application/json"]
    },
    "member": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/member",
      "dataFormats": ["application/json"]
    },
    "nodeRequest": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/node-request",
      "dataFormats": ["application/json"]
    },
    "node": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/node",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "nodeInfo": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/node-info",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "endpoint": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/endpoint",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "aclPolicy": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/acl-policy",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "relay": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/relay",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "preAuthKey": {
      "schema": "https://enbox.id/schemas/wireguard-mesh/pre-auth-key",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    }
  },
  "structure": {
    "network": {
      "$encryption": {
        "rootKeyId": "#dwn-enc",
        "publicKeyJwk": {}
      },
      "$actions": [
        { "who": "anyone", "can": ["read"] }
      ],

      "member": {
        "$role": true,
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "update", "co-delete", "co-prune"] },
          { "role": "network/member", "can": ["read"] },
          { "role": "network/node", "can": ["read"] }
        ],

        "nodeRequest": {
          "$size": { "max": 2000 },
          "$actions": [
            { "who": "recipient", "of": "network/member", "can": ["create", "delete"] },
            { "who": "author", "of": "network", "can": ["read", "co-delete"] },
            { "role": "network/member", "can": ["read"] }
          ]
        },

        "node": {
          "$role": true,
          "$squash": true,
          "$size": { "max": 10000 },
          "$encryption": {
            "rootKeyId": "#dwn-enc",
            "publicKeyJwk": {}
          },
          "$actions": [
            { "who": "author", "of": "network", "can": ["create", "update", "delete"] },
            { "role": "network/member", "can": ["read"] },
            { "role": "network/node", "can": ["read"] }
          ],

          "nodeInfo": {
            "$squash": true,
            "$size": { "max": 5000 },
            "$encryption": {
              "rootKeyId": "#dwn-enc",
              "publicKeyJwk": {}
            },
            "$actions": [
              { "who": "recipient", "of": "network/member/node", "can": ["create", "update"] },
              { "role": "network/member", "can": ["read"] },
              { "role": "network/node", "can": ["read"] }
            ]
          },

          "endpoint": {
            "$squash": true,
            "$size": { "max": 2000 },
            "$encryption": {
              "rootKeyId": "#dwn-enc",
              "publicKeyJwk": {}
            },
            "$actions": [
              { "who": "recipient", "of": "network/member/node", "can": ["create", "update"] },
              { "role": "network/member", "can": ["read"] },
              { "role": "network/node", "can": ["read"] }
            ]
          }
        }
      },

      "nodeRequest": {
        "$size": { "max": 2000 },
        "$actions": [
          { "who": "anyone", "can": ["create"] },
          { "who": "author", "of": "network", "can": ["create", "read", "delete", "co-delete"] }
        ]
      },

      "node": {
        "$role": true,
        "$squash": true,
        "$size": { "max": 10000 },
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "update", "delete"] },
          { "role": "network/member", "can": ["read"] },
          { "role": "network/node", "can": ["read"] }
        ],

        "nodeInfo": {
          "$squash": true,
          "$size": { "max": 5000 },
          "$encryption": {
            "rootKeyId": "#dwn-enc",
            "publicKeyJwk": {}
          },
          "$actions": [
            { "who": "recipient", "of": "network/node", "can": ["create", "update"] },
            { "role": "network/member", "can": ["read"] },
            { "role": "network/node", "can": ["read"] }
          ]
        },

        "endpoint": {
          "$squash": true,
          "$size": { "max": 2000 },
          "$encryption": {
            "rootKeyId": "#dwn-enc",
            "publicKeyJwk": {}
          },
          "$actions": [
            { "who": "recipient", "of": "network/node", "can": ["create", "update"] },
            { "role": "network/member", "can": ["read"] },
            { "role": "network/node", "can": ["read"] }
          ]
        }
      },

      "aclPolicy": {
        "$squash": true,
        "$size": { "max": 100000 },
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "update"] },
          { "role": "network/member", "can": ["read"] },
          { "role": "network/node", "can": ["read"] }
        ]
      },

      "relay": {
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "update", "delete"] },
          { "role": "network/member", "can": ["read"] },
          { "role": "network/node", "can": ["read"] }
        ]
      },

      "preAuthKey": {
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$recordLimit": { "max": 100, "strategy": "reject" },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "delete", "read"] }
        ]
      }
    }
  }
}
