{
  "protocol": "https://enbox.org/protocols/wireguard-mesh",
  "published": true,
  "types": {
    "network": {
      "schema": "https://enbox.org/schemas/wireguard-mesh/network",
      "dataFormats": ["application/json"]
    },
    "node": {
      "schema": "https://enbox.org/schemas/wireguard-mesh/node",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "endpoint": {
      "schema": "https://enbox.org/schemas/wireguard-mesh/endpoint",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "aclPolicy": {
      "schema": "https://enbox.org/schemas/wireguard-mesh/acl-policy",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "relay": {
      "schema": "https://enbox.org/schemas/wireguard-mesh/relay",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    },
    "preAuthKey": {
      "schema": "https://enbox.org/schemas/wireguard-mesh/pre-auth-key",
      "dataFormats": ["application/json"],
      "encryptionRequired": true
    }
  },
  "structure": {
    "network": {
      "$encryption": {
        "rootKeyId": "#dwn-enc",
        "publicKeyJwk": {}
      },
      "$actions": [
        { "who": "anyone", "can": ["read"] }
      ],

      "node": {
        "$role": true,
        "$squash": true,
        "$size": { "max": 10000 },
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "update", "delete"] },
          { "role": "network/node", "can": ["read"] }
        ],

        "endpoint": {
          "$squash": true,
          "$size": { "max": 2000 },
          "$encryption": {
            "rootKeyId": "#dwn-enc",
            "publicKeyJwk": {}
          },
          "$recordLimit": { "max": 1, "strategy": "purgeOldest" },
          "$actions": [
            { "who": "author", "of": "network/node", "can": ["create", "update"] },
            { "role": "network/node", "can": ["read"] }
          ]
        }
      },

      "aclPolicy": {
        "$size": { "max": 100000 },
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$recordLimit": { "max": 1, "strategy": "purgeOldest" },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "update"] },
          { "role": "network/node", "can": ["read"] }
        ]
      },

      "relay": {
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "update", "delete"] },
          { "role": "network/node", "can": ["read"] }
        ]
      },

      "preAuthKey": {
        "$encryption": {
          "rootKeyId": "#dwn-enc",
          "publicKeyJwk": {}
        },
        "$recordLimit": { "max": 100, "strategy": "reject" },
        "$actions": [
          { "who": "author", "of": "network", "can": ["create", "delete", "read"] }
        ]
      }
    }
  }
}
