{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://enbox.id/schemas/wireguard-mesh/node-info",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "hostname": {
      "type": "string",
      "maxLength": 253,
      "description": "Machine hostname"
    },
    "os": {
      "type": "string",
      "enum": ["linux", "darwin", "windows", "freebsd", "android", "ios"],
      "description": "Operating system"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["subnet-router", "exit-node", "relay", "dns"]
      },
      "description": "Capabilities this node advertises"
    }
  }
}
