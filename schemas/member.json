{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://enbox.org/schemas/wireguard-mesh/member",
  "type": "object",
  "required": ["addedAt"],
  "additionalProperties": false,
  "properties": {
    "label": {
      "type": "string",
      "maxLength": 128,
      "description": "Human-readable label for this member"
    },
    "addedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When this member was added to the network"
    }
  }
}
