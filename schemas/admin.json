{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://enbox.org/schemas/wireguard-mesh/admin",
  "type": "object",
  "required": ["grantedAt"],
  "additionalProperties": false,
  "properties": {
    "grantedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When admin privileges were granted"
    },
    "label": {
      "type": "string",
      "maxLength": 128,
      "description": "Human-readable label for this admin"
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["manage-members", "manage-acl", "manage-relays", "manage-preauth"]
      },
      "description": "Specific admin capabilities (all if omitted)"
    }
  }
}
